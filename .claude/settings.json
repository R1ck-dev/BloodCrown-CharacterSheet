{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              ".claude/hooks/check-skills.ps1"
            ],
            "timeout": 10,
            "statusMessage": "Analisando skills do projeto..."
          }
        ]
      }
    ]
  }
}
